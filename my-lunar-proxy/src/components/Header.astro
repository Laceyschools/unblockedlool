---

<header class="bg-[#1a1a1a] p-4 flex items-center justify-between border-b border-[#333]">
  <div class="flex items-center gap-4">
    <img src="/lunar.svg" alt="Lunar" class="h-8 w-8" />
    <h1 class="text-xl font-bold">Lunar v2</h1>
  </div>
  <div class="flex items-center gap-4">
    <div id="clock" class="text-3xl font-mono">00:00:00 PM</div>
    <div id="quote" class="text-sm text-gray-400">this is the quoteeee~</div>
  </div>
</header>

<script>
  function updateClock() {
    const clockElement = document.getElementById('clock');
    if (clockElement) {
      const now = new Date();
      clockElement.innerText = now.toLocaleTimeString();
    }
  }

  updateClock();
  setInterval(updateClock, 1000);
</script>
