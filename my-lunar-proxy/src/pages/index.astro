---
import Layout from '../layouts/Layout.astro';
---

<Layout title="New Tab - Lunar" description="Lunar v2 New Tab">
  <div class="flex flex-col items-center justify-center gap-12 mt-12">
    <div class="w-full max-w-2xl bg-[#1a1a1a] p-4 rounded-full border border-[#333] flex items-center gap-3">
      <input type="text" id="search-input" placeholder="Search or type a URL..." class="flex-1 bg-transparent text-white outline-none text-lg" />
      <button id="search-button" class="p-2 bg-[#333] rounded-full hover:bg-[#444]">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </button>
    </div>

    <div class="grid grid-cols-6 gap-6 w-full max-w-4xl">
      <a href="/proxy?url=https://www.youtube.com" class="bg-[#1a1a1a] p-6 rounded-2xl flex flex-col items-center gap-3 border border-[#333] hover:bg-[#222]">
        <img src="https://www.youtube.com/s/desktop/9986561f/img/favicon_144x144.png" alt="YouTube" class="h-12 w-12" />
        <span>YouTube</span>
      </a>
      </div>
  </div>
</Layout>

<script>
  const searchInput = document.getElementById('search-input');
  const searchButton = document.getElementById('search-button');

  searchButton.addEventListener('click', () => {
    const url = searchInput.value;
    if (url) {
      window.location.href = `/proxy?url=${encodeURIComponent(url)}`;
    }
  });

  searchInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      const url = searchInput.value;
      if (url) {
        window.location.href = `/proxy?url=${encodeURIComponent(url)}`;
      }
    }
  });
</script>
